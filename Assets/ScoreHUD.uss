.hud-root {
    position: absolute;
    left: 16px;
    top: 16px;

    padding-left: 12px;
    padding-right: 12px;
    padding-top: 10px;
    padding-bottom: 10px;

    background-color: rgba(0, 0, 0, 0.55);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
}

.hud-label {
    font-size: 18px;
    margin-bottom: 6px;
    color: white;
    -unity-font-style: bold;
}

.powerup-timer {
    color: yellow;
}